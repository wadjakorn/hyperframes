# No environment variables required for basic usage.
# Run `bun run dev` to start the studio, `npx hyperframes render` to render video.

# Optional integrations:
# GEMINI_API_KEY=        # AI image captioning during website capture (~$0.001/image, https://aistudio.google.com/apikey)

# Caption transcription via API (dev-ui caption flow → Provider dropdown).
# The dev-ui server (scripts/dev-ui-web.mjs) loads .env from the repo root, so
# these light up the OpenAI / OpenRouter providers with no launch-command changes.
# OPENAI_API_KEY=sk-...          # OpenAI Whisper / gpt-4o-transcribe (https://platform.openai.com/api-keys)
# OPENROUTER_API_KEY=sk-or-...   # OpenRouter STT routing — Whisper, Groq, Chirp (https://openrouter.ai/keys)
